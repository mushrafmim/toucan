# Toucan Backend Configuration

# Server settings
TOUCAN_HTTP_ADDR=:8080

# Database settings
TOUCAN_POSTGRES_DSN=postgres://postgres:postgres@localhost:5432/toucan?sslmode=disable

# Authentication settings
TOUCAN_AUTH_ENABLED=false
TOUCAN_AUTH_ISSUER=
TOUCAN_AUTH_AUDIENCE=
TOUCAN_AUTH_JWKS_URL=
TOUCAN_AUTH_JWKS_CACHE_TTL=15m

# Dev user settings (used when auth is disabled or for local dev)
TOUCAN_DEV_USER_SUBJECT=dev-user
TOUCAN_DEV_USER_EMAIL=dev@toucan.local
TOUCAN_DEV_USER_ROLES=admin,instructor,learner
TOUCAN_DEV_USER_SCOPES=dev

# Storage settings
# Driver can be 'local' or 's3'
TOUCAN_BLOB_DRIVER=local
TOUCAN_LOCAL_STORAGE_PATH=./uploads
# TOUCAN_S3_BUCKET=
# TOUCAN_S3_REGION=us-east-1
